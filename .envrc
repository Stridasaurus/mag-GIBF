export CONDA_DEFAULT_ENV=mhd-env
# Conda root is derived from $HOME so the pinned env resolves on any machine
# (audit W-F fix); override with MHD_CONDA_ROOT if conda lives elsewhere.
if [[ "$(uname)" == "Darwin" ]]; then
  MHD_CONDA_ROOT="${MHD_CONDA_ROOT:-/opt/homebrew/Caskroom/miniconda/base}"
  _env="$MHD_CONDA_ROOT/envs/mhd-env"
  export CONDA_PREFIX="$_env"
  PATH_add "$_env/bin"
else
  MHD_CONDA_ROOT="${MHD_CONDA_ROOT:-$HOME/miniconda3}"
  _env="$MHD_CONDA_ROOT/envs/mhd-env"
  export CONDA_PREFIX="$(cygpath -w "$_env" 2>/dev/null || echo "$_env")"
  PATH_add "$_env/bin"
  PATH_add "$_env/Scripts"
  PATH_add "$_env/Library/bin"
  PATH_add "$_env/Library/usr/bin"
  PATH_add "$_env/Library/mingw-w64/bin"
  PATH_add "$_env"
fi
